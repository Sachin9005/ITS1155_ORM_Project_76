<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="16"
      fx:controller="lk.ijse.serenity.controller.TherapistPanelController">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Therapist Management" styleClass="page-title"/>
            <Label text="Manage therapists and program assignments" styleClass="page-subtitle"/>
        </VBox>
        <Button text="+ Add Therapist" styleClass="btn-primary" onAction="#openAddDialog"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="12">
        <TableView fx:id="therapistTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colName" text="Name" prefWidth="160"/>
                <TableColumn fx:id="colSpec" text="Specialization" prefWidth="160"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                <TableColumn fx:id="colPhone" text="Phone" prefWidth="120"/>
                <TableColumn fx:id="colAvail" text="Availability" prefWidth="130"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="170"/>
            </columns>
            <placeholder>
                <Label text="No therapists found."/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- Add/Edit Form -->
    <VBox fx:id="formCard" styleClass="card" spacing="14" managed="false" visible="false">
        <HBox alignment="CENTER_LEFT">
            <Label fx:id="formTitle" text="Add Therapist"
                   style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1a3a3c;" HBox.hgrow="ALWAYS"/>
            <Button text="✕" styleClass="btn-secondary,btn-small" onAction="#closeForm"/>
        </HBox>
        <Separator/>
        <GridPane hgap="16" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>
            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Full Name *" styleClass="form-label"/>
                <TextField fx:id="fName" promptText="Dr. Nimal Silva"/>
            </VBox>
            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Specialization" styleClass="form-label"/>
                <TextField fx:id="fSpec" promptText="e.g. Cognitive Behavioral Therapy"/>
            </VBox>
            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Email *" styleClass="form-label"/>
                <TextField fx:id="fEmail" promptText="doctor@serenity.lk" onKeyReleased="#validateEmail"/>
            </VBox>
            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Phone * (0XXXXXXXXX)" styleClass="form-label"/>
                <TextField fx:id="fPhone" promptText="0111234567" onKeyReleased="#validatePhone"/>
            </VBox>
            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label text="Availability" styleClass="form-label"/>
                <TextField fx:id="fAvail" promptText="Mon-Fri 9am-5pm"/>
            </VBox>
            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label text="Qualification" styleClass="form-label"/>
                <TextField fx:id="fQual" promptText="MBBS, MD Psychiatry"/>
            </VBox>
        </GridPane>
        <Label fx:id="formError" styleClass="error-label" wrapText="true"/>
        <HBox spacing="10">
            <Button text="Save Therapist" styleClass="btn-primary" onAction="#saveTherapist"/>
            <Button text="Cancel" styleClass="btn-secondary" onAction="#closeForm"/>
        </HBox>
    </VBox>
</VBox>
